{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "title": "Chassis entity / data model",
  "description": "Defines a data model / entity — a persistent domain object with fields, relationships, constraints, and lifecycle rules.",
  "type": "object",
  "required": [
    "entityId",
    "description",
    "status",
    "fields",
    "relationships",
    "indexes",
    "timestamps",
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "entityId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Z][a-zA-Z0-9]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated"
      ]
    },
    "tableName": {
      "type": "string",
      "minLength": 1
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/FieldDefinition"
      }
    },
    "relationships": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/RelationshipDefinition"
      }
    },
    "indexes": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/IndexDefinition"
      }
    },
    "timestamps": {
      "type": "object",
      "required": [
        "createdAt",
        "updatedAt",
        "deletedAt"
      ],
      "additionalProperties": false,
      "properties": {
        "createdAt": {
          "type": "boolean"
        },
        "updatedAt": {
          "type": "boolean"
        },
        "deletedAt": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "versioning": {
      "$ref": "#/$defs/Versioning"
    },
    "tags": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "FieldDefinition": {
      "$ref": "../../../schemas/field-definition.schema.json"
    },
    "RelationshipDefinition": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "target"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "has_one",
            "has_many",
            "belongs_to",
            "many_to_many"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "foreignKey": {
          "type": "string"
        },
        "cascade": {
          "type": "string",
          "enum": [
            "none",
            "delete",
            "nullify",
            "restrict"
          ],
          "default": "none"
        }
      }
    },
    "IndexDefinition": {
      "type": "object",
      "required": [
        "fields"
      ],
      "additionalProperties": false,
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "unique": {
          "type": "boolean",
          "default": false
        },
        "name": {
          "type": "string"
        }
      }
    },
    "Versioning": {
      "type": "object",
      "required": [
        "strategy"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "none",
            "optimistic",
            "event-sourced"
          ]
        },
        "field": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
