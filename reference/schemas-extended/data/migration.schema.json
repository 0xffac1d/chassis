{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "title": "Chassis schema migration record",
  "description": "Records a schema migration — a structural change to an entity that must be tracked and reversible.",
  "type": "object",
  "required": [
    "migrationId",
    "entity",
    "description",
    "timestamp",
    "operations",
    "reversible"
  ],
  "additionalProperties": false,
  "properties": {
    "migrationId": {
      "type": "string",
      "minLength": 1
    },
    "entity": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/MigrationOp"
      }
    },
    "reversible": {
      "type": "boolean"
    },
    "rollback": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "MigrationOp": {
      "type": "object",
      "required": [
        "action",
        "target",
        "details"
      ],
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "add_field",
            "remove_field",
            "rename_field",
            "add_index",
            "remove_index",
            "add_relationship",
            "alter_type",
            "add_constraint",
            "remove_constraint"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
