{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.1",
  "title": "Chassis API endpoint contract",
  "description": "Defines the contract for a single API endpoint (REST, GraphQL mutation/query, gRPC method). Every endpoint that serves external or internal consumers should have this contract.",
  "type": "object",
  "required": [
    "endpointId",
    "method",
    "path",
    "summary",
    "status",
    "auth",
    "request",
    "response"
  ],
  "additionalProperties": false,
  "properties": {
    "endpointId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
    },
    "apiFamily": {
      "type": "string",
      "description": "Transport/contract family (P1.2).",
      "enum": [
        "rest",
        "grpc",
        "graphql",
        "webhook",
        "streaming",
        "rpc-generic"
      ]
    },
    "method": {
      "type": "string",
      "enum": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "QUERY",
        "MUTATION",
        "SUBSCRIPTION",
        "RPC"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "auth": {
      "$ref": "#/$defs/Auth"
    },
    "request": {
      "$ref": "#/$defs/Request"
    },
    "response": {
      "$ref": "#/$defs/Response"
    },
    "rateLimit": {
      "$ref": "#/$defs/RateLimit"
    },
    "cache": {
      "$ref": "#/$defs/Cache"
    },
    "idempotency": {
      "$ref": "#/$defs/Idempotency"
    },
    "pagination": {
      "$ref": "#/$defs/Pagination"
    },
    "tags": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ParamDefinition": {
      "type": "object",
      "required": [
        "name",
        "type",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "validation": {
          "type": "string"
        },
        "default": {}
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": [
        "status",
        "code",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Auth": {
      "type": "object",
      "required": [
        "required",
        "methods"
      ],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean"
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scopes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RequestBody": {
      "type": "object",
      "required": [
        "contentType",
        "schema"
      ],
      "additionalProperties": false,
      "properties": {
        "contentType": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      }
    },
    "Request": {
      "type": "object",
      "required": [
        "headers",
        "pathParams",
        "queryParams"
      ],
      "additionalProperties": false,
      "properties": {
        "headers": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ParamDefinition"
          }
        },
        "pathParams": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ParamDefinition"
          }
        },
        "queryParams": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ParamDefinition"
          }
        },
        "body": {
          "$ref": "#/$defs/RequestBody"
        }
      }
    },
    "SuccessResponse": {
      "type": "object",
      "required": [
        "status",
        "contentType",
        "schema"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "contentType": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        }
      }
    },
    "Response": {
      "type": "object",
      "required": [
        "success",
        "errors"
      ],
      "additionalProperties": false,
      "properties": {
        "success": {
          "$ref": "#/$defs/SuccessResponse"
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ErrorResponse"
          }
        }
      }
    },
    "RateLimit": {
      "type": "object",
      "required": [
        "requests",
        "window",
        "scope"
      ],
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "integer",
          "minimum": 1
        },
        "window": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": [
            "ip",
            "user",
            "api-key",
            "global"
          ]
        }
      }
    },
    "Cache": {
      "type": "object",
      "required": [
        "strategy",
        "ttl",
        "varyBy"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "none",
            "public",
            "private",
            "stale-while-revalidate"
          ]
        },
        "ttl": {
          "type": "string",
          "minLength": 1
        },
        "varyBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Idempotency": {
      "type": "object",
      "required": [
        "supported",
        "behavior"
      ],
      "additionalProperties": false,
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "keyHeader": {
          "type": "string"
        },
        "behavior": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Pagination": {
      "type": "object",
      "required": [
        "style",
        "defaultPageSize",
        "maxPageSize"
      ],
      "additionalProperties": false,
      "properties": {
        "style": {
          "type": "string",
          "enum": [
            "cursor",
            "offset",
            "keyset",
            "page-number"
          ]
        },
        "defaultPageSize": {
          "type": "integer",
          "minimum": 1
        },
        "maxPageSize": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
