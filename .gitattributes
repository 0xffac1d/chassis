# gitattributes — release source archive policy.
#
# `scripts/build-source-archive.sh` runs `git archive`, which honors any
# pathspec marked with `export-ignore` below. Exclude only local/editor noise
# and generated outputs that must never appear in archives.
#
# Active docs (`README.md`), `CLAUDE.md`, `.gitignore`, `.github/workflows/`,
# and `reference/` MUST ship in release source archives — `scripts/docs-lint.sh`
# and `scripts/check-archive-hygiene.sh` require paths that reference them.
#
# Self-attest output stays out of archives (`self-attest-artifacts/` is gitignored).

# Local pipeline output (defensive — should not be committed).
/self-attest-artifacts/** export-ignore

# Agent/IDE scaffolding at repo root — not release surface.
/.cursor/**             export-ignore
/.claude/**             export-ignore

# Optional agent router derivative; canonical tree context is README + CLAUDE.md.
AGENTS.md               export-ignore

# Tooling/editor config that does not affect consumers of source tarballs.
.gitattributes          export-ignore
.editorconfig           export-ignore
