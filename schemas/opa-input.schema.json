{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chassis.dev/schemas/opa-input/v1",
  "version": "1.3.0",
  "title": "Chassis OPA input export (v1)",
  "description": "OPA adapter wrapping Chassis policy-input facts under the standard `input` key. Mirrors `schemas/policy-input.schema.json` field-for-field so `opa eval --schema schemas/opa-input.schema.json` type-checks Rego policies against the canonical Chassis fact shape. Chassis does not evaluate Rego.",
  "type": "object",
  "additionalProperties": false,
  "required": ["input"],
  "properties": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "repo",
        "contracts",
        "claims",
        "diagnostics",
        "exemptions",
        "drift_summary",
        "scanner_summaries",
        "scanner_required"
      ],
      "properties": {
        "version": { "type": "integer", "const": 1 },
        "repo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["root"],
          "properties": {
            "root": { "type": "string" },
            "git_commit": { "type": "string" },
            "schema_fingerprint": {
              "type": "string",
              "pattern": "^[a-fA-F0-9]{64}$"
            }
          }
        },
        "contracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/contractFact" }
        },
        "claims": {
          "type": "array",
          "items": { "$ref": "#/$defs/claimFact" }
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        },
        "exemptions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["diagnostics"],
          "properties": {
            "registry": {
              "oneOf": [{ "type": "null" }, { "type": "object" }]
            },
            "diagnostics": {
              "type": "array",
              "items": { "$ref": "#/$defs/diagnostic" }
            }
          }
        },
        "drift_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stale", "abandoned", "missing"],
          "properties": {
            "stale": { "type": "integer", "minimum": 0 },
            "abandoned": { "type": "integer", "minimum": 0 },
            "missing": { "type": "integer", "minimum": 0 }
          }
        },
        "spec_kit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["spec_index_digest"],
          "properties": {
            "spec_index_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          }
        },
        "scanner_summaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/scannerSummary" }
        },
        "scanner_required": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "scannerSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "sarifSha256", "total", "errors", "warnings", "infos", "diagnostics"],
      "properties": {
        "tool": { "type": "string", "enum": ["semgrep", "codeql"] },
        "toolVersion": { "type": "string" },
        "sarifSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "runId": { "type": "string" },
        "total": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "infos": { "type": "integer", "minimum": 0 },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line"],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    },
    "diagnostic": {
      "type": "object",
      "description": "Inline mirror of schemas/diagnostic.schema.json load-bearing fields for OPA input validation (2020-12).",
      "required": ["ruleId", "severity", "message"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "ruleId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*(-[A-Z0-9]+)+$"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "violated": {
          "type": "object",
          "additionalProperties": false,
          "required": ["convention"],
          "properties": {
            "convention": {
              "type": "string",
              "pattern": "^ADR-\\d{4,}$"
            }
          }
        },
        "docs": {
          "type": "string",
          "format": "uri"
        },
        "fix": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicability"],
          "properties": {
            "applicability": {
              "type": "string",
              "enum": ["automatic", "suggested", "manual-only"]
            },
            "description": { "type": "string" },
            "patch": { "type": "string" }
          }
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": { "type": "string" },
            "range": {
              "type": "object",
              "additionalProperties": false,
              "required": ["start"],
              "properties": {
                "start": { "$ref": "#/$defs/position" },
                "end": { "$ref": "#/$defs/position" }
              }
            }
          }
        },
        "detail": {
          "type": "object"
        }
      }
    },
    "contractFact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "name",
        "kind",
        "version",
        "owner",
        "assurance_level",
        "status",
        "document"
      ],
      "properties": {
        "path": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "version": { "type": "string" },
        "owner": { "type": "string" },
        "assurance_level": { "type": "string" },
        "status": { "type": "string" },
        "document": { "type": "object" }
      }
    },
    "claimFact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "contract_path",
        "contract_kind",
        "claim_record",
        "impl_sites",
        "test_sites",
        "adr_refs",
        "active_exemptions"
      ],
      "properties": {
        "claim_id": { "type": "string" },
        "contract_path": { "type": "string" },
        "contract_kind": {
          "type": "string",
          "enum": ["invariant", "edge_case"]
        },
        "claim_record": { "type": "object" },
        "impl_sites": {
          "type": "array",
          "items": { "$ref": "#/$defs/claimSite" }
        },
        "test_sites": {
          "type": "array",
          "items": { "$ref": "#/$defs/claimSite" }
        },
        "adr_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "active_exemptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "claimSite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "claim_id", "kind"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 0 },
        "claim_id": { "type": "string" },
        "kind": { "type": "string", "enum": ["impl", "test"] }
      }
    }
  }
}
