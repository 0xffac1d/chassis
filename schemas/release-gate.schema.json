{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chassis.dev/schemas/release-gate-predicate/v1",
  "version": "1.3.0",
  "title": "Chassis release-gate attestation predicate (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_fingerprint",
    "git_commit",
    "built_at",
    "verdict",
    "fail_on_drift",
    "trace_failed",
    "drift_failed",
    "exemption_failed",
    "attestation_failed",
    "scanner_failed",
    "spec_index_present",
    "spec_index_digest",
    "spec_failed",
    "spec_error_count",
    "unsuppressed_blocking",
    "suppressed",
    "severity_overridden",
    "final_exit_code",
    "trace_summary",
    "drift_summary",
    "exempt_summary",
    "scanner_summary",
    "commands_run"
  ],
  "properties": {
    "schema_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_commit": {
      "type": "string",
      "minLength": 4
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "fail_on_drift": { "type": "boolean" },
    "trace_failed": { "type": "boolean" },
    "drift_failed": { "type": "boolean" },
    "exemption_failed": { "type": "boolean" },
    "attestation_failed": { "type": "boolean" },
    "scanner_failed": { "type": "boolean" },
    "spec_index_present": { "type": "boolean" },
    "spec_index_digest": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    },
    "spec_failed": { "type": "boolean" },
    "spec_error_count": { "type": "integer", "minimum": 0 },
    "unsuppressed_blocking": { "type": "integer", "minimum": 0 },
    "suppressed": { "type": "integer", "minimum": 0 },
    "severity_overridden": { "type": "integer", "minimum": 0 },
    "final_exit_code": { "type": "integer" },
    "trace_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claims", "orphan_sites"],
      "properties": {
        "claims": { "type": "integer", "minimum": 0 },
        "orphan_sites": { "type": "integer", "minimum": 0 }
      }
    },
    "drift_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stale", "abandoned", "missing"],
      "properties": {
        "stale": { "type": "integer", "minimum": 0 },
        "abandoned": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 }
      }
    },
    "exempt_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active", "expired_present"],
      "properties": {
        "active": { "type": "integer", "minimum": 0 },
        "expired_present": { "type": "integer", "minimum": 0 }
      }
    },
    "scanner_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools", "errors", "warnings", "sarifDigests"],
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "sarifDigests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "semgrep": {
              "anyOf": [
                { "type": "null" },
                { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              ]
            },
            "codeql": {
              "anyOf": [
                { "type": "null" },
                { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              ]
            }
          }
        }
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["argv", "exit_code"],
        "properties": {
          "argv": {
            "type": "array",
            "items": { "type": "string" }
          },
          "exit_code": { "type": "integer" }
        }
      }
    }
  }
}
