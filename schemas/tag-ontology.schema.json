{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "title": "Chassis tag ontology registry",
  "description": "Registry-backed tags (P1.1): stable ids, optional namespaces, owners, allowed targets, synonyms, and deprecation. Used as a sidecar or embedded slice; not required for all manifests.",
  "type": "object",
  "required": [
    "tags"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "namespace": {
      "type": "string",
      "description": "Default namespace for tags in this file when a tag omits one."
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/TagDefinition"
      }
    }
  },
  "$defs": {
    "TagDefinition": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_.-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "allowedTargets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "synonyms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "replacedBy": {
          "type": "string"
        }
      }
    }
  }
}
