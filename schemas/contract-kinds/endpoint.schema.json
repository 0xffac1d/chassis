{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chassis.dev/schemas/contract-kinds/endpoint.schema.json",
  "version": "1.0.0",
  "title": "API endpoint contract payload",
  "description": "Schema for kind=endpoint contracts. Requires HTTP method, path, auth, structured request/response.",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^x-[A-Za-z0-9_.-]+$": {
      "type": "object",
      "description": "Vendor extension namespace; values must be objects."
    }
  },
  "required": [
    "name",
    "kind",
    "purpose",
    "status",
    "since",
    "version",
    "assurance_level",
    "owner",
    "invariants",
    "edge_cases",
    "method",
    "path",
    "auth",
    "request",
    "response"
  ],
  "properties": {
    "kind": {
      "const": "endpoint"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "stable",
        "deprecated",
        "active",
        "archived",
        "inferred",
        "superseded",
        "pre-alpha"
      ]
    },
    "since": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "assurance_level": {
      "type": "string",
      "enum": [
        "declared",
        "coherent",
        "verified",
        "enforced",
        "observed"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120,
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "test_linkage": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "edge_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120,
            "pattern": "^[a-z][a-z0-9_.-]*$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "test_linkage": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "superseded_by": {
      "type": "string",
      "minLength": 1
    },
    "linked_objectives": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_.-]*$",
        "minLength": 3
      }
    },
    "ring": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "schemaRef": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Structured declared inputs."
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "schemaRef": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Structured declared outputs."
    },
    "drift": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skip_exports": {
          "type": "boolean"
        },
        "language": {
          "type": "string",
          "enum": [
            "auto",
            "typescript",
            "rust",
            "none"
          ]
        },
        "ignore_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "package_layer": {
          "type": "string",
          "minLength": 1
        },
        "tier": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "debt": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "owner": {
            "type": "string"
          },
          "remediation": {
            "type": "string"
          }
        }
      }
    },
    "generated": {
      "type": "boolean"
    },
    "rationale": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "test_linkage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "test_file"
        ],
        "additionalProperties": false,
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "test_file": {
            "type": "string",
            "minLength": 1
          },
          "validation_method": {
            "type": "string",
            "enum": [
              "test",
              "runtime-assertion",
              "monitor",
              "manual"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "depended_by": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "architecture_system": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
    },
    "extensions": {
      "type": "object",
      "description": "Namespaced extensions.",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object"
      }
    },
    "method": {
      "type": "string",
      "enum": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "HEAD",
        "OPTIONS"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "auth": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "request": {
      "type": "object",
      "required": [
        "content_type"
      ],
      "additionalProperties": false,
      "properties": {
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "schema_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "response": {
      "type": "object",
      "required": [
        "content_type"
      ],
      "additionalProperties": false,
      "properties": {
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "status_code": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        }
      }
    },
    "request_examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "value": {}
        }
      }
    },
    "response_examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "value": {}
        }
      }
    }
  }
}
