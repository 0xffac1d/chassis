{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chassis.dev/schemas/trace-graph/v1",
  "title": "Chassis trace graph (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["claims", "orphan_sites", "diagnostics"],
  "properties": {
    "claims": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["claim_id", "contract_path", "contract_kind", "claim_record", "impl_sites", "test_sites", "adr_refs", "active_exemptions"],
        "properties": {
          "claim_id": { "type": "string" },
          "contract_path": { "type": "string" },
          "contract_kind": { "type": "string", "enum": ["invariant", "edge_case"] },
          "claim_record": { "type": "object" },
          "impl_sites": {
            "type": "array",
            "items": { "$ref": "#/$defs/claimSite" }
          },
          "test_sites": {
            "type": "array",
            "items": { "$ref": "#/$defs/claimSite" }
          },
          "adr_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "active_exemptions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "orphan_sites": {
      "type": "array",
      "items": { "$ref": "#/$defs/claimSite" }
    },
    "diagnostics": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "$defs": {
    "claimSite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "claim_id", "kind"],
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 0 },
        "claim_id": { "type": "string" },
        "kind": { "type": "string", "enum": ["impl", "test"] }
      }
    }
  }
}
