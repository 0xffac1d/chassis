{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "title": "Shared field definition",
  "description": "Reusable field definition for entity, event, and store schemas. Referenced via $ref from consuming schemas.",
  "type": "object",
  "required": [
    "name",
    "type",
    "description"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "string",
        "integer",
        "float",
        "boolean",
        "datetime",
        "uuid",
        "json",
        "enum",
        "text",
        "binary"
      ]
    },
    "required": {
      "type": "boolean",
      "default": true
    },
    "unique": {
      "type": "boolean",
      "default": false
    },
    "indexed": {
      "type": "boolean",
      "default": false
    },
    "default": {},
    "validation": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "enumValues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sensitive": {
      "type": "boolean",
      "default": false
    }
  }
}
