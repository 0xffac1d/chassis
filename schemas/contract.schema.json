{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chassis.dev/schemas/contract.schema.json",
  "version": "3.0.0",
  "title": "Module CONTRACT",
  "description": "Machine-readable metadata for a code module (CONTRACT.yaml). Kind-discriminated contracts defer payload constraints to per-kind subschemas under schemas/contract-kinds/.",
  "allOf": [
    {
      "type": "object",
      "required": [
        "name",
        "kind",
        "purpose",
        "status",
        "since",
        "version",
        "assurance_level",
        "owner",
        "invariants",
        "edge_cases"
      ]
    },
    {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "library"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/library.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "cli"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/cli.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "component"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/component.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "endpoint"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/endpoint.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "entity"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/entity.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "service"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/service.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "event-stream"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/event-stream.schema.json"
            }
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "const": "feature-flag"
            }
          },
          "required": [
            "kind"
          ],
          "allOf": [
            {
              "$ref": "./contract-kinds/feature-flag.schema.json"
            }
          ]
        }
      ]
    }
  ],
  "type": "object",
  "required": [
    "name",
    "kind",
    "purpose",
    "status",
    "since",
    "version",
    "assurance_level",
    "owner",
    "invariants",
    "edge_cases"
  ]
}
